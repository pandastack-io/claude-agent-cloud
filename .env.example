# claude-agent-cloud configuration. Copy to .env and fill in, then:
#   set -a; . ./.env; set +a   &&   ./run.sh

# --- required ---

# Your self_hosted environment id (env_…). Printed by ./scripts/setup_anthropic.sh
ANTHROPIC_ENVIRONMENT_ID=env_...

# The environment KEY (sk-ant-oat01-…). Generated in the Console only:
#   Workspace → Environments → claude-agent-cloud → Generate environment key
# NOTE: this is NOT your org API key. The worker host only needs this one.
ANTHROPIC_ENVIRONMENT_KEY=sk-ant-oat01-...

# Your PandaStack API token (pds_…), from https://app.pandastack.ai → API Tokens
PANDASTACK_API_KEYEY=pds_...

# --- optional ---

# What to do with a session's microVM between turns:
#   hibernate (default) — snapshot + stop; sub-second auto-wake, state intact, scale to zero
#   running             — leave it up; lowest next-turn latency, holds resources
#   delete              — tear down; ~180ms recreate next turn, loses /workspace state
# CMA_ON_IDLE=hibernate

# Where session outputs are downloaded (default ./outputs)
# CMA_OUTPUTS_DIR=outputs

# --- only needed to drive a demo session with scripts/run_demo.py ---
# Your org API key (session creation is an operator-side call)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# The demo agent id (agent_…), printed by setup_anthropic.sh
# CMA_AGENT_ID=agent_...
